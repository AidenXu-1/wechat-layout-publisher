# Advanced fallback only.
# Recommended for normal users: run `npm run setup` in scripts/
# to save credentials in macOS Keychain or Windows Credential Manager.
# Do not distribute a filled .env file.

# WeChat Official Account — 公众号后台 → 开发 → 基本配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# OpenAI — used only when generating cover images with --gen-cover
OPENAI_API_KEY=
# Optional override. Current default: gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-2
